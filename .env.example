# URL base da API do backend UniCarona.
# O Expo expõe apenas variáveis com prefixo EXPO_PUBLIC_ para o app mobile.
#
# Quando alterar este valor:
# - Ao trocar de rede Wi-Fi (o IP local da sua máquina pode mudar)
# - Ao desenvolver em outro computador
# - Ao testar em dispositivo físico (celular) — localhost NÃO funciona no aparelho
#
# Como descobrir seu IP local:
# - Windows: ipconfig (use o IPv4 da interface Wi-Fi/Ethernet ativa)
# - macOS/Linux: ip addr ou ifconfig
#
# Celular e computador devem estar na mesma rede Wi-Fi.
# Após editar, reinicie o Expo com cache limpo: npx expo start -c

EXPO_PUBLIC_API_URL=http://SEU_IP:3333
